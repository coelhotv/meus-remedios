# Supabase Configuration
# You'll get these values from your Supabase project dashboard
SUPABASE_URL=your-project-url-here

VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Admin Chat ID for DLQ Digest notifications
# Get your chat ID by messaging @userinfobot on Telegram
ADMIN_CHAT_ID=123456789

# External Cron Secret (for cron-job.org)
CRON_SECRET=create-a-random-secret-key-here

VERCEL_TOKEN=your-vercel-token-here

VERCEL_GITHUB_ACTIONS_SECRET=your-vercel-github-actions-secret-here

BLOB_READ_WRITE_TOKEN=your-blob-read-write-token-here

GITHUB_TOKEN=your-github-token-here