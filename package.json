{
  "name": "dosiq",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @dosiq/web",
    "build": "npm run build --workspace @dosiq/web",
    "lint": "eslint .",
    "preview": "npm run preview --workspace @dosiq/web",
    "dev:web": "npm run dev --workspace @dosiq/web",
    "build:web": "npm run build --workspace @dosiq/web",
    "preview:web": "npm run preview --workspace @dosiq/web",
    "test:web": "npm run test --workspace @dosiq/web",
    "// --- Test Scripts (Testing Infrastructure Overhaul) ---": "",
    "test": "npm run test --workspace @dosiq/web",
    "test:watch": "npm run test:watch --workspace @dosiq/web",
    "test:smoke": "npm run test:smoke --workspace @dosiq/web",
    "test:critical": "npm run test:critical --workspace @dosiq/web",
    "test:unit": "npm run test:unit --workspace @dosiq/web",
    "test:changed": "npm run test:changed --workspace @dosiq/web",
    "test:coverage": "npm run test:coverage --workspace @dosiq/web",
    "test:components": "npm run test:components --workspace @dosiq/web",
    "test:services": "npm run test:services --workspace @dosiq/web",
    "test:fast": "npm run test:fast --workspace @dosiq/web",
    "test:lowram": "npm run test:lowram --workspace @dosiq/web",
    "// --- Validation Scripts (with timeout protection) ---": "",
    "validate:quick": "npm run lint && npm run validate:quick --workspace @dosiq/web",
    "validate:agent": "npm run validate:agent --workspace @dosiq/web",
    "validate:full": "npm run lint && npm run validate:full --workspace @dosiq/web",
    "// --- Other Scripts ---": "",
    "bot": "cd server && npm run dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/blob": "^2.3.0",
    "dotenv": "^17.2.3",
    "expo-server-sdk": "^6.1.0",
    "framer-motion": "^12.33.0",
    "groq-sdk": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.0.1",
    "qrcode": "^1.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-virtuoso": "^4.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "iconv-lite": "^0.7.2",
    "jose": "^6.1.3",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "typescript": "~5.9.2",
    "vite": "^7.2.4",
    "vitest": "^4.0.16",
    "yaml-lint": "^1.7.0"
  },
  "overrides": {
    "esbuild": "^0.26.0",
    "react-native-safe-area-context": "5.4.0"
  }
}
