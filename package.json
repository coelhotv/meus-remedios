{
  "name": "meus-remedios",
  "private": true,
  "version": "3.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "// --- Test Scripts (Testing Infrastructure Overhaul) ---": "",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run --config vitest.smoke.config.js",
    "test:critical": "vitest run --config vitest.critical.config.js",
    "test:unit": "vitest run --config vitest.config.js",
    "test:changed": "vitest run --changed=main",
    "test:coverage": "vitest run --config vitest.ci.config.js",
    "test:components": "vitest run src/components src/shared/components",
    "test:services": "vitest run src/services src/features",
    "test:fast": "vitest run",
    "test:lowram": "vitest run --config vitest.lowram.config.js",
    "// --- Validation Scripts (with timeout protection) ---": "",
    "validate:quick": "npm run lint && node scripts/run-tests-with-timeout.mjs 300 npm run test:changed",
    "validate:agent": "node scripts/run-tests-with-timeout.mjs 600 npm run -- test:critical --bail=1",
    "validate:full": "npm run lint && node scripts/run-tests-with-timeout.mjs 900 npm run test:coverage && npm run build",
    "// --- Other Scripts ---": "",
    "bot": "cd server && npm run dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@supabase/supabase-js": "^2.90.1",
    "@vercel/blob": "^2.3.0",
    "dotenv": "^17.2.3",
    "expo": "^55.0.9",
    "framer-motion": "^12.33.0",
    "groq-sdk": "^1.1.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-virtuoso": "^4.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "iconv-lite": "^0.7.2",
    "jose": "^6.1.3",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "typescript": "~5.9.2",
    "vite": "^7.2.4",
    "vitest": "^4.0.16",
    "yaml-lint": "^1.7.0"
  },
  "overrides": {
    "esbuild": "^0.26.0"
  }
}
