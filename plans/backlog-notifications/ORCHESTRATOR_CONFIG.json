{
  "project": "Notifications Architecture Consolidation",
  "version": "1.0.0",
  "orchestration": {
    "strict_mode": true,
    "require_human_approval_per_gate": true,
    "quality_gates": {
      "pre_coding": [
        "check_duplicates",
        "verify_contract_existence",
        "validate_spec_schema"
      ],
      "post_coding": [
        "rtk lint",
        "rtk npm run test:critical",
        "verify_passthrough_removal",
        "verify_no_leakage_L1_to_L3"
      ]
    },
    "sub_agent_profile": {
      "role": "specialist-coder",
      "constraints": [
        "R-220 (3-Layer Architecture)",
        "R-200 (Notification Gate)",
        "R-030 (Numeric Indices)",
        "R-060 (No Self-Merge)"
      ],
      "output_format": "json_report"
    },
    "process_protocol": {
      "branching": "feat/gate-{id}-{slug}",
      "lint_policy": "Zero new regressions. Strict complexity < 15.",
      "pr_protocol": "Create PR using docs/standards/PULL_REQUEST_TEMPLATE.md. Wait for Human Review.",
      "hard_stop": "Absolute halt before any git commit/push until manual validation is confirmed."
    }
  },
  "gates": [
    {
      "id": 1,
      "name": "Schema & Contract Hardening",
      "spec": "EXEC_SPEC_GATE_1_schema_contract.md",
      "validation_rules": [
        "grep -q 'metadataSchema' server/notifications/payloads/buildNotificationPayload.js",
        "! grep -q 'passthrough()' server/notifications/payloads/buildNotificationPayload.js"
      ],
      "status": "merged"
    },
    {
      "id": 2,
      "name": "L2 Absorption",
      "spec": "EXEC_SPEC_GATE_2_l2_absorption.md",
      "validation_rules": [
        "! ls bot/utils/doseFormatters.js"
      ],
      "status": "merged"
    },
    {
      "id": 3,
      "name": "L1 Cleanup",
      "spec": "EXEC_SPEC_GATE_3_l1_cleanup.md",
      "validation_rules": [
        "! grep -q 'formatMedicineWithStrength' server/bot/tasks.js",
        "! grep -q '📈' server/bot/tasks.js"
      ],
      "status": "merged"
    },
    {
      "id": 4,
      "name": "L3 Cleanup",
      "spec": "EXEC_SPEC_GATE_4_l3_cleanup.md",
      "validation_rules": [
        "! grep -q 'formatMessage' server/notifications/channels/telegramChannel.js",
        "grep -q 'payload.actions' server/notifications/channels/telegramChannel.js"
      ],
      "status": "merged"
    },
    {
      "id": 5,
      "name": "Dispatcher Boundary Cleanup",
      "spec": "EXEC_SPEC_GATE_5_dispatcher_boundary.md",
      "validation_rules": [
        "! grep -q 'payload || buildNotificationPayload' server/notifications/dispatcher/dispatchNotification.js",
        "! grep -q 'isGroupedKind' server/notifications/dispatcher/dispatchNotification.js"
      ],
      "status": "review"
    },
    {
      "id": 5.5,
      "name": "Inbox Markdown Renderer",
      "spec": "EXEC_SPEC_GATE_5_5_inbox_renderer.md",
      "validation_rules": [
        "grep -q 'parseTelegramMarkdown' apps/web/src/features/notifications/components/InboxItem.js || true",
        "npm run test:critical"
      ],
      "status": "planned"
    },
    {
      "id": 6,
      "name": "Validation & Docs",
      "spec": "EXEC_SPEC_GATE_6_validation_docs.md",
      "validation_rules": [
        "ls docs/architecture/NOTIFICATIONS.md",
        "npm run validate:agent"
      ],
      "status": "planned"
    }
  ]
}
